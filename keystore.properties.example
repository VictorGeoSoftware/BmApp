# Copy this file to `keystore.properties` (same directory) and fill in the
# real values. The actual file is gitignored. Env vars override these:
#   KEYSTORE_PATH, KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD
#
# storeFile may be absolute or relative to the BmApp/ root.

storeFile=../BM_Keystore.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
